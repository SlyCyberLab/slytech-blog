---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/categories/detection', label: 'Categories' },
  { href: '/about', label: 'About' },
  { href: 'https://github.com/SlyCyberLab', label: 'GitHub', external: true },
];

const current = Astro.url.pathname;
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-dot"></span>
      <span class="logo-text">SLYTECH<span class="logo-slash">/</span>BLOG</span>
    </a>

    <ul class="nav-links">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: !link.external && current === link.href }]}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button class="nav-mobile-btn" id="nav-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile-menu" id="nav-mobile-menu">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="nav-mobile-link"
        target={link.external ? '_blank' : undefined}
        rel={link.external ? 'noopener noreferrer' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    height: var(--nav-height);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0, 255, 136, 0.6); }
    50% { box-shadow: 0 0 0 6px rgba(0, 255, 136, 0); }
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.05em;
  }

  .logo-slash {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    letter-spacing: 0.03em;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .nav-mobile-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    margin-left: auto;
  }

  .nav-mobile-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text-muted);
    border-radius: 2px;
    transition: background 0.15s;
  }

  .nav-mobile-btn:hover span { background: var(--color-accent); }

  .nav-mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    gap: 0.25rem;
  }

  .nav-mobile-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .nav-mobile-link:last-child { border-bottom: none; }
  .nav-mobile-link:hover { color: var(--color-accent); }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-mobile-btn { display: flex; }
    .nav {
      height: auto;
      min-height: var(--nav-height);
    }
    .nav-inner { padding: 0 1.5rem; height: var(--nav-height); }
  }

  @media (max-width: 640px) {
    .nav-mobile-menu.open { display: flex; }
  }
</style>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('open'));
</script>
